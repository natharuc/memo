<Window x:Class="Memo.JanelaLembretes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lembretes" Width="500" Height="600"
        Icon="memo.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="{DynamicResource CorFundo}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lembretes" Foreground="{DynamicResource CorTexto}"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <!-- Formulário de criação -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="LEMBRAR DE" Foreground="{DynamicResource CorTextoFraco}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="campoTexto" />

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="QUANDO (dd/mm/aaaa hh:mm)" Foreground="{DynamicResource CorTextoFraco}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox x:Name="campoQuando" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="REPETIR (min)" Foreground="{DynamicResource CorTextoFraco}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox x:Name="campoRepetir" Text="0" Width="90" />
                </StackPanel>
            </Grid>

            <TextBlock x:Name="textoErro" Foreground="{DynamicResource CorPerigo}" FontSize="12"
                       TextWrapping="Wrap" Visibility="Collapsed" Margin="0,8,0,0" />

            <Button Content="Adicionar lembrete" Style="{StaticResource BotaoPrimario}"
                    HorizontalAlignment="Left" Margin="0,12,0,0" Click="Adicionar_Click" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="SEUS LEMBRETES" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8" />

        <Border Grid.Row="3" Background="{DynamicResource CorPainel}" CornerRadius="10" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="listaLembretes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Margin="0,1" CornerRadius="8" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Texto}" Foreground="{DynamicResource CorTexto}"
                                                   FontSize="14" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Resumo}" Foreground="{DynamicResource CorTextoFraco}"
                                                   FontSize="12" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Tag="{Binding Id}"
                                            Style="{StaticResource BotaoPerigo}" Padding="10,4"
                                            VerticalAlignment="Center" Click="Excluir_Click" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <CheckBox x:Name="chkInicio" Grid.Row="4" Margin="0,14,0,0"
                  Content="Iniciar com o Windows (para os lembretes avisarem sempre)"
                  Click="Inicio_Click" />

        <Grid Grid.Row="5" Margin="0,16,0,0">
            <Button Content="🔔 Tocar agora" Click="Testar_Click" HorizontalAlignment="Left"
                    ToolTip="Mostra um lembrete de exemplo (com o som) para você ver como fica." />
            <Button Content="Fechar" Click="Fechar_Click" IsCancel="True" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</Window>
