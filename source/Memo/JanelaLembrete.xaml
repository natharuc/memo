<Window x:Class="Memo.JanelaLembrete"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="True" FontFamily="Segoe UI" Title="Lembrete">
    <Border CornerRadius="14" Width="380" Padding="24"
            Background="{DynamicResource CorPainel}"
            BorderBrush="{DynamicResource CorBorda}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.55" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="⏰ Lembrete" Foreground="{DynamicResource CorDestaque}"
                       FontSize="13" FontWeight="SemiBold" />
            <TextBlock x:Name="textoLembrete" Foreground="{DynamicResource CorTexto}"
                       FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,8,0,20" />

            <Button Content="Concluído" Style="{StaticResource BotaoPrimario}"
                    HorizontalAlignment="Stretch" Padding="16,10" Click="Concluir_Click" />

            <TextBlock Text="ADIAR" Foreground="{DynamicResource CorTextoFraco}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,18,0,6" />
            <StackPanel Orientation="Horizontal">
                <Button Content="5 min" Tag="5" Click="Adiar_Click" Margin="0,0,8,0" />
                <Button Content="10 min" Tag="10" Click="Adiar_Click" Margin="0,0,8,0" />
                <Button Content="15 min" Tag="15" Click="Adiar_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
