<Window x:Class="Memo.JanelaGerarSenha"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerar senha" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="{DynamicResource CorFundo}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Senha gerada + ações -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="campoSenha" Grid.Column="0" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="17" VerticalContentAlignment="Center" />
            <Button x:Name="botaoRegerar" Grid.Column="1" Content="↻" FontSize="16"
                    Margin="8,0,0,0" ToolTip="Gerar outra" Click="Regerar_Click" />
        </Grid>

        <!-- Barra de força -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="barraForca" Grid.Column="0" Height="6" Minimum="0" Maximum="1"
                         Background="{DynamicResource CorBorda}" BorderThickness="0"
                         VerticalAlignment="Center" />
            <TextBlock x:Name="textoForca" Grid.Column="1" Margin="12,0,0,0" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <!-- Comprimento -->
        <TextBlock Grid.Row="2" Text="NÚMERO DE CARACTERES" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8" />
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="textoComprimento" Grid.Column="0" Width="32" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource CorTexto}" VerticalAlignment="Center" />
            <Slider x:Name="controleComprimento" Grid.Column="1" Minimum="6" Maximum="40" Value="16"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    ValueChanged="Comprimento_ValueChanged" />
        </Grid>

        <!-- Conjuntos -->
        <TextBlock Grid.Row="4" Text="CARACTERES UTILIZADOS" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8" />
        <WrapPanel Grid.Row="5">
            <CheckBox x:Name="optMaiusculas" Content="Letra maiúscula" IsChecked="True"
                      Margin="0,0,18,8" Click="Opcao_Click" />
            <CheckBox x:Name="optMinusculas" Content="Letra minúscula" IsChecked="True"
                      Margin="0,0,18,8" Click="Opcao_Click" />
            <CheckBox x:Name="optNumeros" Content="Números" IsChecked="True"
                      Margin="0,0,18,8" Click="Opcao_Click" />
            <CheckBox x:Name="optSimbolos" Content="Símbolos" IsChecked="True"
                      Margin="0,0,0,8" Click="Opcao_Click" />
        </WrapPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancelar" Click="Cancelar_Click" IsCancel="True" Margin="0,0,8,0" />
            <Button Content="Usar senha" Style="{StaticResource BotaoPrimario}"
                    Click="Usar_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
