<Window x:Class="Memo.JanelaEditar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documento" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="{DynamicResource CorFundo}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="CHAVE" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox x:Name="campoChave" Grid.Row="1" />

        <TextBlock Grid.Row="2" Text="VALOR" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,14,0,4" />
        <TextBox x:Name="campoValor" Grid.Row="3" MinHeight="90" MaxHeight="220"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" />

        <TextBlock x:Name="textoErro" Grid.Row="4" Margin="0,10,0,0"
                   Foreground="{DynamicResource CorPerigo}" FontSize="12"
                   TextWrapping="Wrap" Visibility="Collapsed" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancelar" Click="Cancelar_Click" IsCancel="True" Margin="0,0,8,0" />
            <Button Content="Salvar" Style="{StaticResource BotaoPrimario}"
                    Click="Salvar_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
