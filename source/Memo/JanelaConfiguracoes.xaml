<Window x:Class="Memo.JanelaConfiguracoes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="{DynamicResource CorFundo}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configurações"
                   Foreground="{DynamicResource CorTexto}" FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <!-- Tema -->
        <TextBlock Grid.Row="1" Text="TEMA" Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
        <StackPanel x:Name="painelTema" Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Escuro" Tag="Escuro" Click="Tema_Click" Margin="0,0,8,0" />
            <Button Content="Claro" Tag="Claro" Click="Tema_Click" />
        </StackPanel>

        <!-- Duração da sessão -->
        <TextBlock Grid.Row="3" Text="TEMPO PARA GUARDAR A SENHA"
                   Foreground="{DynamicResource CorTextoFraco}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="4"
                   Text="Depois de destrancar, o cofre fica acessível por esse tempo sem pedir a senha de novo."
                   Foreground="{DynamicResource CorTextoFraco}" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,10" />
        <WrapPanel x:Name="painelDuracao" Grid.Row="5" Margin="0,0,0,4">
            <Button Content="15 min" Tag="15" Click="Duracao_Click" Margin="0,0,8,8" />
            <Button Content="30 min" Tag="30" Click="Duracao_Click" Margin="0,0,8,8" />
            <Button Content="1 hora" Tag="60" Click="Duracao_Click" Margin="0,0,8,8" />
            <Button Content="4 horas" Tag="240" Click="Duracao_Click" Margin="0,0,8,8" />
            <Button Content="8 horas" Tag="480" Click="Duracao_Click" Margin="0,0,8,8" />
            <Button Content="1 dia" Tag="1440" Click="Duracao_Click" Margin="0,0,8,8" />
        </WrapPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancelar" Click="Cancelar_Click" IsCancel="True" Margin="0,0,8,0" />
            <Button Content="Salvar" Style="{StaticResource BotaoPrimario}"
                    Click="Salvar_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
